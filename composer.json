{
  "name": "yoosuf/laravel-dataflow",
  "description": "Streaming-first Laravel data pipeline package for filter/search/sort/import/export workflows at any scale with queue-native execution.",
  "version": "0.9.2",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "laravel-package",
    "dataflow",
    "eloquent",
    "query-builder",
    "filter",
    "search",
    "sort",
    "import",
    "export",
    "streaming",
    "csv",
    "xlsx",
    "ndjson",
    "parquet",
    "etl",
    "reporting",
    "large-datasets",
    "queue"
  ],
  "authors": [
    {
      "name": "Yoosuf"
    }
  ],
  "suggest": {
    "openspout/openspout": "Required for streaming XLSX export/import support.",
    "dompdf/dompdf": "Required for PDF export support.",
    "codename/parquet": "Required for Parquet writer integration."
  },
  "require": {
    "php": "^8.3",
    "illuminate/bus": "^11.0|^12.0",
    "illuminate/cache": "^11.0|^12.0",
    "illuminate/contracts": "^11.0|^12.0",
    "illuminate/database": "^11.0|^12.0",
    "illuminate/filesystem": "^11.0|^12.0",
    "illuminate/http": "^11.0|^12.0",
    "illuminate/queue": "^11.0|^12.0",
    "illuminate/support": "^11.0|^12.0"
  },
  "require-dev": {
    "dompdf/dompdf": "^3.1",
    "infection/infection": "^0.29",
    "laravel/pint": "^1.18",
    "openspout/openspout": "^5.3",
    "orchestra/testbench": "^9.0|^10.0",
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0",
    "phpstan/phpstan": "^1.12",
    "phpstan/phpstan-deprecation-rules": "^1.2",
    "phpstan/phpstan-phpunit": "^1.4",
    "rector/rector": "^1.2"
  },
  "autoload": {
    "psr-4": {
      "Yoosuf\\LaravelDataFlow\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Yoosuf\\LaravelDataFlow\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "bench": "php benchmarks/export_import_benchmark.php",
    "test": "vendor/bin/pest",
    "lint": "vendor/bin/pint --test",
    "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
    "mutation": "vendor/bin/infection --threads=2 --min-msi=70 --min-covered-msi=80",
    "refactor": "vendor/bin/rector process --dry-run",
    "coverage": "vendor/bin/pest --coverage --min=90",
    "release:check": [
      "@lint",
      "@analyse",
      "@test"
    ]
  },
  "extra": {
    "laravel": {
      "providers": [
        "Yoosuf\\LaravelDataFlow\\DataFlowServiceProvider"
      ],
      "aliases": {
        "DataFlow": "Yoosuf\\LaravelDataFlow\\DataFlow"
      }
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
